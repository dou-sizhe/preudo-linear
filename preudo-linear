\section{伪线性算法}
对于迭代次数$n$，求解对应的有限时间线性系统最优控制问题
\begin{equation}
    \begin{aligned}
        n=0:\ \min\ &J_0^{[0]}=x_1^{[0]\top}V(x_0)x_1^{[0]}+x_0^\top Q(x_0)x_0+u_0^\top R(x_0)u_0\\
        s.t.\ &x_1^{[0]}=A(x_0)x_0+B(x_0)u_0\\
        n=1:\ \min\ &J_0^{[1]}=x_2^{[1]\top}V(x_1^{[0]})x_2^{[1]}+\sum_{k=i}^{1}x_k^{[1]\top}Q(x_k^{[0]})x_k^{[1]}+u_k^\top R(x_k^{[0]})u_k\\
        s.t.\ &x_2^{[1]}=A(x_1^{[0]})x_1^{[1]}+B(x_1^{[0]})u_1\\
        \ &x_1^{[1]}=A(x_0)x_0+B(x_0)u_0\\
        \vdots\quad\qquad\qquad&\\
        n=l:\ \min\ &J_0^{[l]}=x_{l+1}^{[l]\top}V(x_l^{[l-1]})x_{l+1}^{[l]}+\sum_{k=i}^{l}x_k^{[l]}Q(x_k^{[l-1]})x_k^{[l]}+u_k^\top R(x_k^{[l-1]})u_k\\
        s.t.\ &x_{k+1}^{[l]}=A(x_k^{[l-1]})x_k^{[l]}+B(x_k^{[l-1]})u_k,\quad k=0,1,\dots,l\\
        \vdots\quad\qquad\qquad&
    \end{aligned}
    \label{iteration-formulation}
\end{equation}

