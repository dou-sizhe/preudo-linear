\begin{equation}
    \begin{aligned}
        P_k^{[i]}&=Q(x_k^{[i-1]})+A(x_k^{[i-1]})^\top P_{k+1}^{[i]}A(x_k^{[i-1]})-A(x_k^{[i-1]})^\top P_{k+1}^{[i]}B(x_k^{[i-1]})\\
        &\times\left(R(x_k^{[i-1]})+B^\top(x_k^{[i-1]})P_{k+1}^{[i]}B(x_k^{[i-1]})\right)^{-1}B^\top(x_k^{[i-1]})P_{k+1}^{[i]}A(x_k^{[i-1]})
    \end{aligned}
\end{equation}
