\section{性质(收敛性、最优性证明)}

\begin{theorem}
    对任意的$n=l,l+1$，在相应的最优控制律(\ref{control-law})作用下，两次迭代的最优代价函数为$J_0^{[l]},J_0^{[l+1]}$，最优的状态轨迹为$x_k^{[l]},x_k^{[l+1]}$，构造辅助函数$\Lambda^{[l]},\Gamma^{[l]}$满足
    \begin{align}
        \Gamma^{[l]}&=x_{l+1}^{[l]\top}V(x_{l+1}^{[l]})x_{l+1}^{[l]}+\sum_{k=0}^lx_k^{[l]\top}Q(x_k^{[l]})x_k^{[l]}+u_k^{[l]\top}R(x_k^{[l]})u_k^{[l]}\\
        \Lambda^{[l]}&=x_{l+1}^{[l+1]\top}V(x_{l+1}^{[l]})x_{l+1}^{[l+1]}+\sum_{k=0}^lx_k^{[l+1]\top}Q(x_k^{[l]})x_k^{[l+1]}+u_k^{[l+1]\top}R(x_k^{[l]})u_k^{[l+1]}
    \end{align}
    则以下不等式成立
    \begin{equation}
        J_0^{[l]*}\ge\Gamma^{[l]}\ge\Lambda^{[l]}=J_0^{[l+1]*}
    \end{equation}
\end{theorem}

\begin{proof}
    第一步，证明$\Lambda^{[l]}=J_0^{[l+1]*}$。由$J_0^{[l+1]}$定义，可得
    \begin{equation}
        \begin{aligned}
            J_0^{[l+1]*}&=x_{l+2}^{[l+1]\top}V(x_{l+1}^{[l]})x_{l+2}^{[l+1]}+x_{l+1}^{[l+1]\top}Q(x_{l+1}^{[l]})x_{l+1}^{[l+1]}+u_{l+1}^{[l+1]\top}R(x_{l+1}^{[l]})u_{l+1}^{[l+1]}\\
            &+\sum_{k=0}^lx_k^{[l+1]\top}Q(x_k^{[l]})x_k^{[l+1]}+u_k^{[l+1]\top}R(x_k^{[l]})u_k^{[l+1]}
        \end{aligned}    
    \end{equation}
    将式(\ref{feedback-iteration-system})与式(\ref{control-law})代入上式中，利用式(\ref{algebraic-riccati})，即得
    \begin{equation}
        \begin{aligned}
            J_0^{[l+1]*}&=x_{l+1}^{[l+1]\top}V(x_{l+1}^{[l]})x_{l+1}^{[l+1]}+\sum_{k=0}^lx_k^{[l+1]\top}Q(x_k^{[l]})x_k^{[l+1]}+u_k^{[l+1]\top}R(x_k^{[l]})u_k^{[l+1]}\\
            &=\Lambda^{[l]}
        \end{aligned}
        \label{lambda-equality}
    \end{equation}
    第二步，证明$\Gamma^{[l]}\ge\Lambda^{[l]}$。由式(\ref{lambda-equality})，可知
    $\Lambda^{[l]}$是第$l+1$次迭代对应的线性系统的最优代价，$\left\{x_k^{[l+1]},u_k^{[l+1]}\right\}_{k=0}^{l+1}$为该线性系统的最优轨迹与最优控制律。
    而$\left\{x_k^{[l]},u_k^{[l]}\right\}_{k=0}^{l+1}$仅为满足当前线性系统方程的一组可行轨迹与可行控制律，根据最优代价的定义，必然有$\Gamma^{[l]}\ge\Lambda^{[l]}$。\\
    \begin{equation}
        \begin{aligned}
            \Gamma^{[l]}&=\left(x_{l+1}^{\top}V(x_{l+1}^{[l]})x_{l+1}+\sum_{k=0}^lx_k^{\top}Q(x_k^{[l]})x_k+u_k^{\top}R(x_k^{[l]})u_k\right)\bigg|_{x_k=x_k^{[l]},u_k=u_k^{[l]}}\\
            &\ge \min_{x_k,u_k}\left\{x_{l+1}^{\top}V(x_{l+1}^{[l]})x_{l+1}+\sum_{k=0}^lx_k^{\top}Q(x_k^{[l]})x_k+u_k^{\top}R(x_k^{[l]})u_k\right\}\\
            &=\Lambda^{[l]}
        \end{aligned}
    \end{equation}
    最后，证明$J_0^{[l]*}\ge\Gamma^{[l]}$。
    \begin{equation}
        \begin{aligned}
            J_0^{[l]}-\Gamma^{[l]}&=x_{l+1}^{[l]\top}(V(x_l^{[l-1]})-V(x_{l+1}^{[l]}))x_{l+1}^{[l]}\\
            &+\sum_{k=0}^{l}x_k^{[l]\top}(Q(x_k^{[l-1]})-Q(x_k^{[l]}))x_k^{[l]}+u_k^{[l]\top}(R(x_k^{[l-1]})-R(x_k^{[l]}))u_k^{[l]}\\
        \end{aligned}
    \end{equation}

    % $J_0^{[l]*}=x_{l+1}^{[l]\top}V(x_l^{[l-1]})x_{l+1}^{[l]}+\sum_{k=0}^{l}x_k^{[l]}Q(x_k^{[l-1]})x_k^{[l]}+u_k^\top R(x_k^{[l-1]})u_k$\\
    % $\Gamma^{[l]}=x_{l+1}^{[l]\top}V(x_l^{[l]})x_{l+1}^{[l]}+\sum_{k=0}^lx_k^{[l]\top}Q(x_k^{[l]})x_k^{[l]}+u_k^{[l]\top}R(x_k^{[l]})u_k^{[l]}$
\end{proof}

